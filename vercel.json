{
  "redirects": [
    {
      "source": "/:path((?!es-MX|en-US)($|/.*))",
      "has": [
        {
          "type": "header",
          "key": "Accept-Language",
          "value": "(^es-MX|^es)"
        }
      ],
      "permanent": false,
      "destination": "/es-MX/:path*"
    },
    {
      "source": "/:path((?!es-MX|en-US)($|/.*))",
      "permanent": false,
      "destination": "/en-US/:path*"
    }
  ],
  "rewrites": [
    {
      "source": "/es-MX/:path*([^.]*)",
      "destination": "/es-MX/index.html"
    },
    {
      "source": "/en-US/:path*([^.]*)",
      "destination": "/en-US/index.html"
    }
  ]
}