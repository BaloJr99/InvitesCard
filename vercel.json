{
  "redirects": [
    {
      "source": "/:path((?!es-MX|en-US/).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept-Language",
          "value": "(^es-MX.*|es.*)"
        }
      ],
      "destination": "/es-MX/:path*"
    },{
      "source": "/:path((?!es-MX|en-US/).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept-Language",
          "value": "(^(?!es-MX.*|es.*).*)"
        }
      ],
      "destination": "/en-US/:path*"
    }
  ],
  "rewrites": [
    { 
      "source": "/es-MX/(.*)", 
      "destination": "/es-MX/" 
    },
    { 
      "source": "/en-US/(.*)",
      "destination": "/en-US/" 
    }
  ]
}