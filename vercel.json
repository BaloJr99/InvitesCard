{
  "redirects": [
    {
      "source": "/:path((?!es-MX|en-US|static|_next|favicon.ico).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept-Language",
          "value": "(^es-MX|^es.*MX.*)"
        }
      ],
      "permanent": false,
      "destination": "/es-MX/:path*"
    },
    {
      "source": "/:path((?!es-MX|en-US|static|_next|favicon.ico).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept-Language",
          "value": "(^en-US|^en.*US.*)"
        }
      ],
      "permanent": false,
      "destination": "/en-US/:path*"
    },
    {
      "source": "/:path((?!es-MX|en-US|static|_next|favicon.ico).*)",
      "permanent": false,
      "destination": "/en-US/:path*"
    }
  ]
}