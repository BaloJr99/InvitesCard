    "@angular/platform-browser": "21.2.16",
    "@angular/platform-browser-dynamic": "21.2.16",
    "@angular/router": "21.2.16",
    "@auth0/angular-jwt": "5.2.0",
    "angularx-qrcode": "21.0.5",
    "bootstrap": "5.3.8",
    "chart.js": "4.5.1",
    "dotenv": "17.4.2",
    "jasmine": "5.13.0",
    "jquery": "4.0.0",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.2",
    "socket.io-client": "4.8.3",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
