{
  "name": "invites",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "node -r dotenv/config mynode.js && ng build --localize",
    "start:dev": "node -r dotenv/config mynode.development.js && ng serve --configuration=en",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "lint": "ng lint",
    "playwright": "npx playwright test --ui"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.16",
